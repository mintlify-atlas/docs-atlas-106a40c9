  "keyFeatures": [
    "Django Ninja REST API with OpenAPI documentation",
    "Web scraping with BeautifulSoup and cloudscraper",
    "Redis caching with intelligent invalidation",
    "Optional Celery for asynchronous tasks",
    "Advanced fuzzy search with trigram matching",
    "Rate limiting and API key authentication",
    "Comprehensive data models for clubs, kits, seasons, brands",
    "Prometheus metrics and Grafana dashboards",
    "Docker and docker-compose deployment",
    "PostgreSQL with full-text search extensions"
  ],
  "publicApiSurface": [
    "GET /api/health - Health check endpoint",
    "GET /api/clubs - List and search clubs",
    "GET /api/clubs/{id} - Get club details",
    "GET /api/clubs/{id}/seasons - Get club seasons",
    "GET /api/kits - List and search kits",
    "GET /api/kits/{id} - Get kit details",
    "GET /api/kits/bulk - Bulk kit retrieval",
    "GET /api/seasons - List and search seasons",
    "GET /api/seasons/{id} - Get season details",
    "GET /api/brands - List and search brands",
    "GET /api/brands/bulk - Bulk brand retrieval",
    "GET /api/competitions - List competitions",
    "GET /api/competitions/bulk - Bulk competition retrieval",
    "GET /api/colors - List colors",
    "GET /api/user-collection/{userid} - Get user collection",
    "POST /api/user-collection/{userid}/scrape - Trigger user collection scrape",
    "GET /api/metrics - Get system metrics"
  ]
}
